# TikTok Live Viewers - Configuration Example
# Copiar este archivo a .env y ajustar según sea necesario

# Puerto del servidor
PORT=3000

# Ambiente
NODE_ENV=development

# Configuración de TikTok Live Connector
# Timeout por defecto en ms
TIKTOK_CONNECTION_TIMEOUT=15000

# Opcional: API Key para signing (si deseas usar Euler Stream)
# TIKTOK_SIGN_API_KEY=your-api-key-here

# Configuración de logging
LOG_LEVEL=debug

# Opcional: Si deseas enviar mensajes a TikTok, necesitas autenticación
# TIKTOK_SESSION_ID=your_session_id
# TIKTOK_TARGET_IDC=your_target_idc
